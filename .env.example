# ============================================================
# 企业微信(wecom)通道配置
# ============================================================

# ===== 企微应用凭证 =====
# 企业ID（在"我的企业"页面获取）
WECOM_CORP_ID=your-corp-id-here

# 应用AgentId（在应用详情页获取）
WECOM_AGENT_ID=1000001

# 应用Secret（在应用详情页获取）
WECOM_CORP_SECRET=your-app-secret-here

# ===== 回调配置 =====
# 企微回调URL（zCloud暴露给企微的webhook地址）
# 需要在企微应用管理后台配置
WECOM_CALLBACK_URL=https://your-domain.com/api/v1/channels/wecom/callback

# 回调Token（用于验证签名）
WECOM_CALLBACK_TOKEN=your-random-token-here

# 回调EncodingAESKey（用于消息加解密，选填）
# WECOM_CALLBACK_AES_KEY=your-aes-key-here

# ===== API配置 =====
# 企微API基础地址（通常不需要修改）
WECOM_API_BASE_URL=https://qyapi.weixin.qq.com
WECOM_API_TIMEOUT=30

# ===== 通道开关 =====
# 是否启用企微通道
WECOM_ENABLED=false

# ===== 会话配置 =====
# 会话TTL（秒），默认86400（24小时）
WECOM_SESSION_TTL_SECONDS=86400
# 是否自动创建会话
WECOM_AUTO_CREATE_SESSION=true

# ===== 告警推送配置 =====
# 告警推送目标（群ID或用户userid）
WECOM_ALERT_TARGET=
# 是否自动推送告警通知
WECOM_ALERT_PUSH_ENABLED=false
