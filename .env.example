# ============================================================
# Javis DB Agent - 核心配置
# ============================================================

# 服务绑定地址
JAVIS_HOST=0.0.0.0

# 服务端口
JAVIS_PORT=8000

# Ollama API 地址
OLLAMA_BASE_URL=http://localhost:11434

# Ollama 模型
OLLAMA_MODEL=qwen3.5:35b

# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# 是否启用认证
ENABLE_AUTH=false

# ============================================================
# TLS/SSL配置
# ============================================================
# 是否启用HTTPS（启用后HTTP请求自动重定向到HTTPS）
ZLOUD_HTTPS_ENABLED=false

# 是否启用HSTS（HTTP严格传输安全）
ZLOUD_HSTS_ENABLED=false

# HSTS有效期（秒），默认1年
ZLOUD_HSTS_MAX_AGE=31536000

# 是否包含子域名
ZLOUD_HSTS_INCLUDE_SUBDOMAINS=true

# 是否加入HSTS预加载列表
ZLOUD_HSTS_PRELOAD=false

# SSL证书文件路径（启用HTTPS时必须）
# ZLOUD_SSL_CERT_FILE=/path/to/cert.pem

# SSL私钥文件路径（启用HTTPS时必须）
# ZLOUD_SSL_KEY_FILE=/path/to/key.pem

# 是否验证SSL证书（默认true，Ollama为本地服务可关闭）
ZLOUD_VERIFY_SSL=true

# Ollama SSL验证（本地Ollama可关闭）
ZLOUD_OLLAMA_VERIFY_SSL=true

# Ollama客户端证书（双向TLS时使用）
# ZLOUD_OLLAMA_CLIENT_CERT_FILE=/path/to/client.crt
# ZLOUD_OLLAMA_CLIENT_KEY_FILE=/path/to/client.key
# ZLOUD_OLLAMA_CA_FILE=/path/to/ca.crt

# ============================================================
# 企业微信(wecom)通道配置
# ============================================================

# ===== 企微应用凭证 =====
# 企业ID（在"我的企业"页面获取）
WECOM_CORP_ID=your-corp-id-here

# 应用AgentId（在应用详情页获取）
WECOM_AGENT_ID=1000001

# 应用Secret（在应用详情页获取）
WECOM_CORP_SECRET=your-app-secret-here

# ===== 回调配置 =====
# 企微回调URL（zCloud暴露给企微的webhook地址）
# 需要在企微应用管理后台配置
WECOM_CALLBACK_URL=https://your-domain.com/api/v1/channels/wecom/callback

# 回调Token（用于验证签名）
WECOM_CALLBACK_TOKEN=your-random-token-here

# 回调EncodingAESKey（用于消息加解密，选填）
# WECOM_CALLBACK_AES_KEY=your-aes-key-here

# ===== API配置 =====
# 企微API基础地址（通常不需要修改）
WECOM_API_BASE_URL=https://qyapi.weixin.qq.com
WECOM_API_TIMEOUT=30

# ===== 通道开关 =====
# 是否启用企微通道
WECOM_ENABLED=false

# ===== 会话配置 =====
# 会话TTL（秒），默认86400（24小时）
WECOM_SESSION_TTL_SECONDS=86400
# 是否自动创建会话
WECOM_AUTO_CREATE_SESSION=true

# ===== 告警推送配置 =====
# 告警推送目标（群ID或用户userid）
WECOM_ALERT_TARGET=
# 是否自动推送告警通知
WECOM_ALERT_PUSH_ENABLED=false

# ============================================================
# V2.7: 审批Webhook安全配置
# ============================================================

# Webhook HMAC-SHA256签名密钥（用于验证请求来源）
# 推荐使用: openssl rand -hex 32
APPROVAL_WEBHOOK_SECRET=

# Webhook允许的IP白名单（逗号分隔，支持CIDR）
# 示例: 10.0.0.1,192.168.1.0/24,172.16.0.0/16
APPROVAL_WEBHOOK_ALLOWED_IPS=
